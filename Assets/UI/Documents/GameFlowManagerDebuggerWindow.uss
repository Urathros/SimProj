.root {
    padding-left: 12px;
    padding-right: 12px;
    padding-top: 12px;
}

.title {
    -unity-font-style: bold;
    font-size: 18px;
    margin-bottom: 6px;
}

.flow-list {
    flex-grow: 1;
    margin-top: 10px;
}

.flow-row {
    flex-direction: row;
}

.flow-id {
    flex-grow: 1;
}

.flow-type {
    width: 180px;
}

.flow-valid {
    width: 80px;
}